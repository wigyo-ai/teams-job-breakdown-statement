# =============================================================================
# JBS Platform — Environment Variable Template
# Copy to .env and fill in all values. NEVER commit .env to version control.
#
# Redis is NOT required. h2oGPTe owns conversation history natively.
# Session phase state uses STATE_BACKEND (memory/sqlite/external_redis).
# =============================================================================

# H2O Enterprise h2oGPTe
H2OGPTE_ADDRESS=https://your-h2ogpte-instance.h2o.ai
H2OGPTE_API_KEY=

# Session state (no Redis pod needed)
# Options: memory | sqlite | external_redis
STATE_BACKEND=sqlite
SQLITE_PATH=/tmp/jbs_sessions.db
SESSION_TTL_HOURS=24
# Only required when STATE_BACKEND=external_redis (use managed Redis, not Helm pod)
# REDIS_URL=rediss://:password@your-managed-redis.cache.windows.net:6380/0

# Microsoft Teams (Azure Bot Service)
# Register a bot at https://dev.botframework.com/ or via Azure Bot resource.
# TEAMS_APP_ID    = Application (client) ID of the Azure Bot App Registration
# TEAMS_APP_PASSWORD = Client secret created for that App Registration
TEAMS_APP_ID=
TEAMS_APP_PASSWORD=

# Mozart API
MOZART_API_BASE_URL=https://mozart.certis.internal/api/v1
MOZART_API_KEY=

# Azure AD / SharePoint
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
SP_SITE_URL=https://certissecurity.sharepoint.com/sites/operations
SP_LIBRARY_CORPORATE=
SP_LIBRARY_AVIATION=
SP_LIBRARY_INDUSTRIAL=
SP_LIBRARY_MARITIME=
SP_LIBRARY_RETAIL=

# Document Storage (S3-compatible)
S3_BUCKET=certis-jbs-documents
S3_ENDPOINT_URL=
S3_PREFIX=jbs-documents/
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
DOC_URL_EXPIRY_SECONDS=900

# Internal Services
ORCHESTRATOR_URL=http://localhost:8001
DOCUMENT_GENERATOR_URL=http://localhost:8002
TENANT_ID=certis
